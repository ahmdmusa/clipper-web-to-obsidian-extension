{
  "manifest_version": 2,
  "name": "Clipper — Web to Obsidian",
  "version": "1.0.0",
  "author": "Ahmed Musa",
  "description": "Clip any web page, post, or thread into clean Obsidian-ready Markdown. Works on Facebook, Twitter/X, Reddit, and any website.",
  "homepage_url": "https://github.com/ahmdmusa/",
  "permissions": [
    "activeTab",
    "downloads",
    "tabs",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Clipper — Web to Obsidian",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "96": "icon-96.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "clipper-web-to-obsidian@ahmdmusa",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
